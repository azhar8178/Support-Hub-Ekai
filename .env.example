# =============================================================================
# Ekai — environment variable reference
# Copy this file to .env and fill in the values before running Docker Compose.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (used by Docker Compose to create the database)
# The api-server receives a full DATABASE_URL constructed from these values.
# -----------------------------------------------------------------------------
POSTGRES_DB=ekai
POSTGRES_USER=ekai
POSTGRES_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------------
# Auth mode
#
# "local"  — built-in email + password auth. No external accounts needed.
#             Requires SESSION_SECRET. Recommended for self-hosting.
# "clerk"  — Clerk-based auth (https://clerk.com). Requires CLERK_* keys below.
# -----------------------------------------------------------------------------
AUTH_MODE=local

# -----------------------------------------------------------------------------
# Local auth session secret  (required when AUTH_MODE=local)
# Generate a strong random value with:
#   openssl rand -hex 32
# -----------------------------------------------------------------------------
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Clerk authentication  (only required when AUTH_MODE=clerk)
# Create an application at https://dashboard.clerk.com, then copy the keys.
# CLERK_PUBLISHABLE_KEY  — public key, safe to expose to browsers
# CLERK_SECRET_KEY       — secret key, never expose this
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Portal URL
# The publicly reachable URL of the support portal, used by the API server for
# links in notification emails and as a trusted CORS origin.
# -----------------------------------------------------------------------------
PORTAL_URL=https://support.yourcompany.com

# -----------------------------------------------------------------------------
# Email — AWS SES  (optional)
# Leave all three blank to disable outbound email notifications entirely.
# The IAM user needs ses:SendRawEmail permission.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
EMAIL_FROM=support@yourcompany.com

# -----------------------------------------------------------------------------
# Object storage — Google Cloud Storage  (optional)
# Leave blank to store file attachments as base64 in PostgreSQL (≤5 MB cap).
# Set these to move attachments to GCS for larger files and better performance.
#   DEFAULT_OBJECT_STORAGE_BUCKET_ID — GCS bucket name
#   PRIVATE_OBJECT_DIR               — prefix/directory inside the bucket
# The container must have GOOGLE_APPLICATION_CREDENTIALS or Workload Identity.
# -----------------------------------------------------------------------------
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=attachments

# -----------------------------------------------------------------------------
# Logging
# Valid levels: fatal | error | warn | info | debug | trace
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Docker Compose port mappings  (host ports)
# Change these if the defaults conflict with other services on your host.
# -----------------------------------------------------------------------------
API_PORT=8080
PORTAL_PORT=80
